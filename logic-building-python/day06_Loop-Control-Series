print(f"Sum = {sum}")

print()


# Q9 - Arithmetic Progression (AP)
a = int(input("Enter first term: "))
d = int(input("Enter common difference: "))
n = int(input("Enter number of terms: "))

for i in range(n):
    print(a)
    a += d

print()


# Q10 - Geometric Progression (GP)
a = int(input("Enter first term: "))
r = int(input("Enter common ratio: "))
n = int(input("Enter number of terms: "))

for i in range(n):
    print(a)
    a *= r

print()


# Q11 - Sum of Squares (1² + 2² + 3² + ... + n²)
n = int(input("Enter a number: "))

sum = 0

for i in range(1, n + 1):
    sum += i ** 2

print(f"Sum = {sum}")

print()


# Q12 - Sum of Cubes (1³ + 2³ + 3³ + ... + n³)
n = int(input("Enter a number: "))

sum = 0

for i in range(1, n + 1):
    sum += i ** 3

print(f"Sum = {sum}")

print()


# Q13 - Harmonic Series (1 + 1/2 + 1/3 + ... + 1/n)
n = int(input("Enter a number: "))

sum = 0

for i in range(1, n + 1):
    sum += 1 / i

print(f"Sum = {sum}")

print()


# Q14 - Sum of Powers of 2 (1 + 2 + 4 + ... + 2ⁿ)
n = int(input("Enter a number: "))

sum = 0

for i in range(0, n + 1):
    sum += 2 ** i

print(f"Sum = {sum}")

print()


# Q15 - Sum of Factorials (1! + 2! + 3! + ... + n!)
n = int(input("Enter a number: "))

sum = 0

for i in range(1, n + 1):

    fact = 1

    for j in range(1, i + 1):
        fact *= j

    sum += fact

print(f"Sum = {sum}")

print()


# Q16 - Sum of Geometric Series (1 + x + x² + x³ + ... + xⁿ)
x = int(input("Enter the value of x: "))
n = int(input("Enter the value of n: "))

sum = 0

for i in range(0, n + 1):
    sum += x ** i

print(f"Sum = {sum}")
