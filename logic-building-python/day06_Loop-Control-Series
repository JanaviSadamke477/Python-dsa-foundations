# Q1 - Print Numbers from 1 to 100 and Stop at First Number Divisible by 17
for i in range(1, 101):
    if i % 17 == 0:
        break
    print(i)

print()


# Q2 - Print Numbers from 1 to 100, Skip Multiples of 5
for i in range(1, 101):
    if i % 5 == 0:
        continue
    print(i)

print()


# Q3 - Take 5 Numbers and Skip Zeros
for i in range(5):
    n = int(input("Enter a number: "))

    if n == 0:
        continue

    print(n)

print()


# Q4 - Search a Number in a List and Stop When Found
numbers = [12, 45, 67, 89, 23, 56]

key = int(input("Enter number to search: "))

for num in numbers:
    if num == key:
        print("Number Found")
        break
else:
    print("Number Not Found")

print()


# Q5 - Print Numbers Until a Negative Number is Entered
while True:
    n = int(input("Enter a number: "))

    if n < 0:
        break

    print(n)

print()


# Q6 - Print Only Even Numbers, Skip Odd Numbers
while True:
    n = int(input("Enter a number: "))

    if n < 0:
        break

    if n % 2 != 0:
        continue

    print(n)

print()


# Q7 - Stop When Running Sum Becomes Greater Than 100
sum = 0

while True:
    n = int(input("Enter a number: "))

    sum += n

    if sum > 100:
        break

print(f"Sum = {sum}")

print()


# Q8 - Sum of First 10 Natural Numbers
sum = 0

for i in range(1, 11):
